%%{
  init: {
    'theme': 'base',
    'themeVariables': {
      'lineColor': '#8C9A9E',
      'textColor': '#333333',
      'fontFamily': 'sans-serif'
    },
    'flowchart': {
      'curve': 'basis'
    }
  }
}%%
flowchart LR

    %% 自定義節點樣式 (莫蘭迪色系)
    %% 淺藍色背景、深藍邊框
    classDef blueNode fill:#D6E4F0,stroke:#4B6584,stroke-width:2px,color:#2C3E50,rx:8,ry:8
    %% 粉橘色背景、橘色邊框
    classDef orangeNode fill:#FDEBD0,stroke:#E67E22,stroke-width:2px,color:#873600,rx:8,ry:8
    %% 資料庫專用樣式
    classDef dbNode fill:#E5E7E9,stroke:#7F8C8D,stroke-width:2px,color:#2C3E50
    %% 判斷邏輯專用樣式
    classDef decisionNode fill:#E8DAEF,stroke:#8E44AD,stroke-width:2px,color:#4A235A

    subgraph ClientLayer [用戶端 (Client)]
        Web[網站前端介面]:::blueNode
        Mobile[行動裝置 App]:::blueNode
    end

    subgraph CoreProcessing [核心處理區 (Core Processing)]
        APIGateway[API 閘道器]:::blueNode
        Auth{權限與<br>身分驗證}:::decisionNode
        OrderEngine[訂單處理模組]:::blueNode
        Inventory[庫存管理模組]:::blueNode
        DB[(系統主資料庫)]:::dbNode
    end

    subgraph ExternalAPI [外部 API (External API)]
        Payment[第三方支付網關]:::orangeNode
        Logistics[物流追蹤服務]:::orangeNode
    end

    %% 邏輯連接線與說明
    Web -->|HTTPS Request| APIGateway
    Mobile -->|HTTPS Request| APIGateway
    
    APIGateway -->|Token 驗證| Auth
    Auth -->|驗證失敗 / 拒絕| APIGateway
    Auth -->|驗證通過| OrderEngine
    
    OrderEngine -->|檢查庫存狀態| Inventory
    Inventory -->|扣留庫存數量| DB
    OrderEngine -->|讀寫訂單資料| DB
    
    OrderEngine -->|JSON over REST| Payment
    OrderEngine -->|Webhook Callback| Logistics
